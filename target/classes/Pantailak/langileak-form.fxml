<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="Pantailak.LangileakForm"
      spacing="10"
      alignment="CENTER"
      style="-fx-background-color: white; -fx-padding: 20;">

    <Label text="Langilearen datuak" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <TextField fx:id="txtIzena" promptText="Izena *"/>
    <TextField fx:id="txtErabiltzailea" promptText="Erabiltzailea *"/>
    <PasswordField fx:id="txtPasahitza" promptText="Pasahitza *"/>
    <ComboBox fx:id="comboLanpostu" promptText="Rola *"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Gorde" onAction="#onSave" style="-fx-background-color: #3182ce; -fx-text-fill: white;"/>
        <Button text="Utzi" onAction="#onCancel" style="-fx-background-color: #a0aec0; -fx-text-fill: white;"/>
    </HBox>
</VBox>